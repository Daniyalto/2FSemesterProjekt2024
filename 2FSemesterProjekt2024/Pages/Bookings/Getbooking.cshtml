@page
@model _2FSemesterProjekt2024.Pages.Bookings.GetBookingModel
@{
    ViewData["Title"] = "GetBooking";
}

<h3 style="color:red"> List of bookings</h3>

<table class="table">
    <thead>
        <tr>
            <th> PickupLocation </th>
            <th> DropoffLocation </th>
            <th> BookingTime </th>
            <th> Seats </th>
        </tr>
    </thead>
    <tbody>

        @if (Model != null)
        {
            @foreach (var item in Model.Bookings)
            {
                <tr>
                    <td>  @item.PickupLocation </td>
                    <td>  @item.DropoffLocation  </td>
                    <td>  @item.BookingTime  </td>
                    <td>  @item.Seats  </td>
                      
                    <td>
                       <p>



                            <a asp-page="./Update" class="btn btn-primary">Edit</a>
                            <a asp-page="/Bookings/Delete" class="btn btn-danger">Delete</a>
                            
                            
                            
                           
                       </p>
                    </td>
                </tr>
            }
        }
</table>

<a asp-page="/Bookings/Create" class="btn btn-primary">Create Booking</a>

