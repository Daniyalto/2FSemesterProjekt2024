@page
@model _2FSemesterProjekt2024.Pages.Auth.Bookingss2.GetBookingsModel
@{
    ViewData["Title"] = "GetBookings";
}

<h3 style="color:red"> List of bookings</h3>
<p>
    <a asp-page="/Profile/Profile" asp-route-did="DriverId">Profile</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th> PickupLocation </th>
            <th> DropoffLocation </th>
            <th> BookingTime </th>
            <th> Seats </th>
        </tr>
    </thead>
    <tbody>

        @if (Model != null)
        {
            @foreach (var item in Model.Bookings)
            {
                <tr>
                    <td>  @item.PickupLocation </td>
                    <td>  @item.DropoffLocation  </td>
                    <td>  @item.BookingTime  </td>
                    @if(Model.user)
                    <td>  @item.Seats  </td>

                    <td>
                        <p>

                            <a asp-page="/Bookings/Delete" asp-route-bid="@item.BookingId">Delete</a>|
                            <a asp-page="./Update" asp-route-bid="@item.BookingId">Edit</a>|


                        </p>
                    </td>
                </tr>
            }
        }
</table>